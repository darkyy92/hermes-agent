--- a/hermes_cli/main.py
+++ b/hermes_cli/main.py
@@ -4862,6 +4862,63 @@ def _restore_stashed_changes(
     return True
 
 
+def _apply_local_update_patches(git_cmd: list[str], cwd: Path) -> list[str]:
+    """Apply user-maintained patches after `hermes update` rewrites the repo.
+
+    Patches live outside the source checkout in `<HERMES_HOME>/local-patches/*.patch`.
+    This gives power users a small, explicit overlay mechanism for local product
+    defaults while still allowing the checkout to track upstream. Already-applied
+    patches are skipped by checking whether the reverse patch applies cleanly.
+    """
+    try:
+        from hermes_constants import get_hermes_home
+        patch_dir = get_hermes_home() / "local-patches"
+    except Exception:
+        return []
+
+    if not patch_dir.is_dir():
+        return []
+
+    applied: list[str] = []
+    for patch_path in sorted(patch_dir.glob("*.patch")):
+        reverse_check = subprocess.run(
+            git_cmd + ["apply", "--reverse", "--check", str(patch_path)],
+            cwd=cwd,
+            capture_output=True,
+            text=True,
+        )
+        if reverse_check.returncode == 0:
+            continue
+
+        check = subprocess.run(
+            git_cmd + ["apply", "--check", str(patch_path)],
+            cwd=cwd,
+            capture_output=True,
+            text=True,
+        )
+        if check.returncode != 0:
+            print(f"  ⚠ Local update patch did not apply cleanly: {patch_path.name}")
+            if check.stderr.strip():
+                print(f"    {check.stderr.strip().splitlines()[0]}")
+            continue
+
+        apply = subprocess.run(
+            git_cmd + ["apply", str(patch_path)],
+            cwd=cwd,
+            capture_output=True,
+            text=True,
+        )
+        if apply.returncode == 0:
+            applied.append(patch_path.name)
+        else:
+            print(f"  ⚠ Failed to apply local update patch: {patch_path.name}")
+            if apply.stderr.strip():
+                print(f"    {apply.stderr.strip().splitlines()[0]}")
+    if applied:
+        print(f"  ✓ Applied local update patch overlay: {', '.join(applied)}")
+    return applied
+
+
